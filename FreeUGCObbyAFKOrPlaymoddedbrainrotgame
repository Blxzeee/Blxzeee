--[[ Roblox Executor Script – Teleport player to checkpoints 1 through 50, then to restart part Assumes: - The executor supports setting player character position - Each checkpoint is a BasePart or contains a BasePart - Restart part exists at workspace.Restart.Model.TeleportPart Usage: Paste this script into your executor and run it. ]] local Players = game:GetService("Players") local player = Players.LocalPlayer -- Wait for the character to load local character = player.Character or player.CharacterAdded:Wait() -- Get the humanoid root part (where we teleport) local rootPart = character:FindFirstChild("HumanoidRootPart") or character.PrimaryPart if not rootPart then error("Could not find HumanoidRootPart or PrimaryPart") end -- Helper: get the actual part to teleport to local function getTeleportPart(checkpoint) if checkpoint:IsA("BasePart") then return checkpoint end -- If it's a model, find the first BasePart (usually the main part) for _, child in ipairs(checkpoint:GetDescendants()) do if child:IsA("BasePart") and child.Name ~= "HumanoidRootPart" then return child end end return nil end -- Store original camera mode (optional) local originalCameraMode = workspace.CurrentCamera.CameraType -- Optional: set camera to follow character workspace.CurrentCamera.CameraType = Enum.CameraType.Custom print("Starting checkpoint teleports...") -- Iterate from 1 to 50 for i = 1, 50 do local key = tostring(i) -- workspace.Checkpoints["1"], "2", ... local checkpoint = workspace.Checkpoints:FindFirstChild(key) if not checkpoint then warn("Checkpoint " .. key .. " not found.") else local teleportPart = getTeleportPart(checkpoint) if teleportPart then -- Calculate teleport position (center of part + slight height offset) local targetPosition = teleportPart.Position + Vector3.new(0, 3, 0) -- 3 studs above part -- Teleport the root part rootPart.CFrame = CFrame.new(targetPosition) -- Optional: also teleport the humanoid to prevent falling issues local humanoid = character:FindFirstChildOfClass("Humanoid") if humanoid then humanoid:MoveTo(targetPosition) end print("Teleported to checkpoint " .. key .. " at " .. tostring(targetPosition)) else warn("No BasePart found for checkpoint " .. key) end end -- Wait 0.1 seconds before the next teleport wait(0.01) end print("All checkpoints visited!") -- Now teleport to the restart part print("Teleporting to restart part...") -- Find the restart part local restartModel = workspace:FindFirstChild("Restart") if restartModel then local model = restartModel:FindFirstChild("Model") if model then local teleportPart = model:FindFirstChild("TeleportPart") if teleportPart and teleportPart:IsA("BasePart") then -- Teleport to the restart part local targetPosition = teleportPart.Position + Vector3.new(0, 3, 0) -- 3 studs above part rootPart.CFrame = CFrame.new(targetPosition) local humanoid = character:FindFirstChildOfClass("Humanoid") if humanoid then humanoid:MoveTo(targetPosition) end print("Teleported to restart part at " .. tostring(targetPosition)) else warn("TeleportPart not found or not a BasePart at workspace.Restart.Model.TeleportPart") end else warn("Model not found in workspace.Restart") end else warn("Restart not found in workspace") end -- Restore camera mode (optional) workspace.CurrentCamera.CameraType = originalCameraMode print("Script completed!")
